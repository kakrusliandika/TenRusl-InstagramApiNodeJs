{
  "name": "tenrusl-instagram-api-nodejs",
  "version": "2.0.0",
  "description": "Production-ready Instagram API with official Meta API mode, local Puppeteer mode, and Docker scraper mode.",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "start:prod": "NODE_ENV=production node src/server.js",
    "check": "node scripts/check-syntax.js",
    "test": "node --test",
    "doctor": "node scripts/doctor.js",
    "docker:build": "docker build -f docker/Dockerfile -t tenrusl-instagram-api:latest .",
    "docker:run": "docker run --rm --env-file .env -p 3000:3000 tenrusl-instagram-api:latest"
  },
  "keywords": [
    "instagram",
    "api",
    "meta-api",
    "puppeteer",
    "express",
    "docker",
    "cloudflare",
    "vercel",
    "netlify"
  ],
  "author": "Andika Rusli",
  "license": "MIT",
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "lru-cache": "^11.0.2",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "zod": "^3.24.1"
  },
  "optionalDependencies": {
    "puppeteer": "^24.1.1"
  },
  "devDependencies": {
    "supertest": "^7.0.0"
  }
}
