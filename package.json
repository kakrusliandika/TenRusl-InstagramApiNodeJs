{
  "name": "tenrusl-instagram-api-nodejs",
  "version": "4.0.0",
  "description": "Production-ready Instagram API Gateway contract for Node.js 24 LTS and Node.js 22 compatibility with safe provider adapters, Express, health probes, metrics, tests, and multi-platform deployment templates.",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=22 <25",
    "npm": ">=10"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "check": "node --check src/server.js",
    "test": "node --test",
    "doctor": "node scripts/doctor.js",
    "lint": "node scripts/lint-basic.js"
  },
  "keywords": [
    "instagram",
    "api-gateway",
    "meta-graph-api",
    "express",
    "nodejs24",
    "nodejs22",
    "docker",
    "kubernetes",
    "cloud",
    "observability",
    "production-ready"
  ],
  "author": "Andika Rusli",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "helmet": "^8.0.0",
    "zod": "^3.24.1",
    "serverless-http": "^3.2.0"
  }
}
