# Lingkungan lokal TenRusl Instagram API Gateway
# Salin ke .env untuk pengembangan lokal.

# Konfigurasi waktu jalan
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
TRUST_PROXY=1
APP_NAME="TenRusl Instagram API Gateway"
LOG_LEVEL=info
BODY_LIMIT=256kb
GRACEFUL_SHUTDOWN_MS=10000

# Pemilihan penyedia. Gunakan mock untuk pengembangan lokal yang deterministik.
IG_PROVIDER=mock

# Gunakan origin yang dipisahkan koma. Gunakan * hanya untuk demo publik/API non-sensitif.
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Proteksi API key. API_KEY minimal 16 karakter saat diaktifkan.
API_KEY_ENABLED=false
API_KEY=
METRICS_PUBLIC=false
CAPABILITIES_PUBLIC=false

# Batas laju permintaan
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Batas koleksi
DEFAULT_LIMIT=25
MAX_LIMIT=100

# Batas waktu permintaan penyedia
PROVIDER_REQUEST_TIMEOUT_MS=10000

# Penyedia resmi Instagram Graph / Meta API
META_GRAPH_BASE_URL=https://graph.facebook.com
META_API_VERSION=v23.0
META_ACCESS_TOKEN=
META_IG_USER_ID=

# Adaptor publik. Biarkan nonaktif kecuali sumber data hulu mematuhi ketentuan dan hukum lokal.
PUBLIC_DATA_ENABLED=false
PUBLIC_DATA_UPSTREAM_URL=

# Adaptor authorized lanjutan. Nonaktif secara default. Gunakan hanya untuk data milik sendiri atau izin eksplisit.
AUTHORIZED_PROVIDER_ENABLED=false
AUTHORIZED_SESSION_TOKEN=
AUTHORIZED_INTEGRATION_REVIEWED=false
