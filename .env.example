# TenRusl Instagram API Gateway environment
# Copy to .env and keep secrets out of version control.

# Runtime
NODE_ENV=development
APP_NAME="TenRusl Instagram API Gateway"
HOST=0.0.0.0
PORT=3000
TRUST_PROXY=1
LOG_LEVEL=info
BODY_LIMIT=256kb
GRACEFUL_SHUTDOWN_MS=10000

# Provider selection. Supported values: mock, official, public, authorized.
IG_PROVIDER=mock

# API security. API_KEY must be at least 16 characters when enabled.
API_KEY_ENABLED=false
API_KEY=
CORS_ORIGIN=*

# Rate limits
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Collection limits
DEFAULT_LIMIT=25
MAX_LIMIT=100

# Provider request timeout
PROVIDER_REQUEST_TIMEOUT_MS=10000

# Official Instagram Graph / Meta API provider
META_GRAPH_BASE_URL=https://graph.facebook.com
META_API_VERSION=v23.0
META_ACCESS_TOKEN=
META_IG_USER_ID=

# Public adapter. Keep disabled unless your upstream data source is compliant with terms and local law.
PUBLIC_DATA_ENABLED=false
PUBLIC_DATA_UPSTREAM_URL=

# Advanced authorized adapter. Disabled by default. Use only for owned data or explicit permission.
AUTHORIZED_PROVIDER_ENABLED=false
AUTHORIZED_SESSION_TOKEN=
