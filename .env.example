# ============================================================
# TenRusl Instagram API v2 Environment Example
# Copy this file to .env and adjust the values.
# ============================================================

# App mode:
# - official = Meta Instagram API only
# - scraper  = Puppeteer public scraper only
# - hybrid   = Official first, scraper fallback
APP_MODE=hybrid
NODE_ENV=development
PORT=3000
APP_NAME=TenRusl Instagram API
APP_BASE_URL=http://localhost:3000
LOG_LEVEL=info

# CORS
# Use comma separated origins. Use * only for public demo/non-sensitive API.
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# API key protection for public production API.
API_KEY_ENABLED=false
API_KEY=change_me_to_a_long_random_secret

# Rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Instagram response limits
DEFAULT_FEED_LIMIT=12
MAX_FEED_LIMIT=35

# Cache
CACHE_ENABLED=true
CACHE_TTL_SECONDS=900
CACHE_MAX_ITEMS=500

# Scraper mode
SCRAPER_ENABLED=true
SCRAPE_TIMEOUT_MS=30000
MAX_CONCURRENT_SCRAPES=2
PUPPETEER_HEADLESS=true
PUPPETEER_EXECUTABLE_PATH=
PUPPETEER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126 Safari/537.36

# Official Meta Instagram API mode.
# Required when APP_MODE=official or APP_MODE=hybrid with official enabled.
META_API_ENABLED=false
META_API_VERSION=v23.0
META_ACCESS_TOKEN=
META_IG_USER_ID=
META_USERNAME=
META_TIMEOUT_MS=15000

# Optional gateway usage.
SCRAPER_API_URL=
SCRAPER_API_KEY=
