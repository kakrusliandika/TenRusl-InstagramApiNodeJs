# TenRusl Instagram API Gateway environment
NODE_ENV=development
APP_NAME="TenRusl Instagram API Gateway"
APP_BASE_URL=http://localhost:3000
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
BODY_LIMIT=256kb

# Provider selection: mock | official | public | authorized
IG_PROVIDER=mock

# API security
API_KEY_ENABLED=false
API_KEY=
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
DEFAULT_LIMIT=25
MAX_LIMIT=100
GRACEFUL_SHUTDOWN_MS=10000

# Official Instagram Graph / Meta API provider
META_API_VERSION=v23.0
META_ACCESS_TOKEN=
META_IG_USER_ID=
META_APP_ID=

# Public adapter. Keep disabled unless your upstream data source is compliant with terms and local law.
PUBLIC_DATA_ENABLED=false
PUBLIC_DATA_UPSTREAM_URL=

# Advanced authorized adapter. Disabled by default. Use only for owned data or explicit permission.
AUTHORIZED_PROVIDER_ENABLED=false
AUTHORIZED_SESSION_TOKEN=
