APP_MODE=hybrid
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
CORS_ORIGIN=https://example.com,https://www.example.com
API_KEY_ENABLED=true
API_KEY=replace_with_very_long_random_secret
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
CACHE_ENABLED=true
CACHE_TTL_SECONDS=900
CACHE_MAX_ITEMS=1000
DEFAULT_FEED_LIMIT=12
MAX_FEED_LIMIT=35
SCRAPER_ENABLED=true
SCRAPE_TIMEOUT_MS=30000
MAX_CONCURRENT_SCRAPES=2
PUPPETEER_HEADLESS=true
META_API_ENABLED=true
META_API_VERSION=v23.0
META_ACCESS_TOKEN=replace_with_meta_token
META_IG_USER_ID=replace_with_ig_business_or_creator_user_id
META_USERNAME=kakrusliandika
META_TIMEOUT_MS=15000
