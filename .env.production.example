# TenRusl Instagram API Gateway production environment
# Copy values into your platform secret manager; do not commit real secrets.

# Runtime
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
TRUST_PROXY=1
APP_NAME="TenRusl Instagram API Gateway"
LOG_LEVEL=info
BODY_LIMIT=256kb
GRACEFUL_SHUTDOWN_MS=10000

# Provider selection. Use official for Meta-approved Business/Creator integrations.
IG_PROVIDER=official

# Use comma separated origins. Avoid * for production APIs with secrets.
CORS_ORIGIN=https://your-domain.example

# API key protection. Replace with a long random secret before deploy.
API_KEY_ENABLED=true
API_KEY=replace_with_32_plus_character_random_secret

# Rate limits
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Collection limits
DEFAULT_LIMIT=25
MAX_LIMIT=100

# Provider request timeout
PROVIDER_REQUEST_TIMEOUT_MS=10000

# Official Instagram Graph / Meta API provider. Required when IG_PROVIDER=official.
META_GRAPH_BASE_URL=https://graph.facebook.com
META_API_VERSION=v23.0
META_ACCESS_TOKEN=replace_with_meta_access_token
META_IG_USER_ID=replace_with_instagram_business_or_creator_user_id

# Public adapter. Keep disabled unless your upstream data source is compliant with terms and local law.
PUBLIC_DATA_ENABLED=false
PUBLIC_DATA_UPSTREAM_URL=

# Advanced authorized adapter. Disabled by default. Use only for owned data or explicit permission.
AUTHORIZED_PROVIDER_ENABLED=false
AUTHORIZED_SESSION_TOKEN=
