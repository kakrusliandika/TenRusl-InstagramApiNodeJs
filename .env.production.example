# Lingkungan produksi TenRusl Instagram API Gateway
# Salin nilai ke pengelola rahasia platform; jangan masukkan rahasia asli ke kontrol versi.

# Konfigurasi waktu jalan
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
TRUST_PROXY=1
APP_NAME="TenRusl Instagram API Gateway"
LOG_LEVEL=info
BODY_LIMIT=256kb
GRACEFUL_SHUTDOWN_MS=10000

# Pemilihan penyedia. Gunakan official untuk integrasi Business/Creator yang disetujui Meta.
IG_PROVIDER=official

# Gunakan origin yang dipisahkan koma. Hindari * untuk API produksi yang memakai rahasia.
CORS_ORIGIN=https://your-domain.example

# Proteksi API key. Ganti dengan rahasia acak panjang sebelum penerapan.
API_KEY_ENABLED=true
API_KEY=replace_with_32_plus_character_random_secret
METRICS_PUBLIC=false
CAPABILITIES_PUBLIC=false

# Batas laju permintaan
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Batas koleksi
DEFAULT_LIMIT=25
MAX_LIMIT=100

# Batas waktu permintaan penyedia
PROVIDER_REQUEST_TIMEOUT_MS=10000

# Penyedia resmi Instagram Graph / Meta API. Wajib saat IG_PROVIDER=official.
META_GRAPH_BASE_URL=https://graph.facebook.com
META_API_VERSION=v23.0
META_ACCESS_TOKEN=replace_with_meta_access_token
META_IG_USER_ID=replace_with_instagram_business_or_creator_user_id

# Adaptor publik. Biarkan nonaktif kecuali sumber data hulu mematuhi ketentuan dan hukum lokal.
PUBLIC_DATA_ENABLED=false
PUBLIC_DATA_UPSTREAM_URL=

# Adaptor authorized lanjutan. Nonaktif secara default. Gunakan hanya untuk data milik sendiri atau izin eksplisit.
AUTHORIZED_PROVIDER_ENABLED=false
AUTHORIZED_SESSION_TOKEN=
AUTHORIZED_INTEGRATION_REVIEWED=false
